# Copie este arquivo para .env.supabase e preencha com os dados do Supabase.
# Nao commite o arquivo .env.supabase preenchido.

SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://db.xjrepdfpwokwsgfztwku.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=SUA_SENHA_DO_SUPABASE
SPRING_DATASOURCE_MAX_POOL_SIZE=3
SPRING_DATASOURCE_MIN_IDLE=1

# Se o endpoint direto nao conectar por IPv4, use o Session pooler do Supabase.
# Exemplo:
# SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# SPRING_DATASOURCE_USERNAME=postgres.PROJECT_REF
